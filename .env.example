# OpenChamber Environment Variables
# Copy this file to .env and customize values

# === OpenCode Settings ===
# OpenCode server password (required for API access)
OPENCODE_SERVER_PASSWORD=devonly

# OpenCode plugins to load (comma-separated)
OPENCODE_PLUGINS=oh-my-opencode,lancedb-opencode-pro

# === UI Settings ===
# Web UI password (required for browser authentication)
OPENCHAMBER_UI_PASSWORD=chamber

# === Ollama Settings ===
# Ollama base URL (internal Docker network URL)
OLLAMA_BASE_URL=http://ollama:11434

# Embedding provider and model (for LanceDB)
LANCEDB_OPENCODE_PRO_EMBEDDING_PROVIDER=ollama
LANCEDB_OPENCODE_PRO_EMBEDDING_MODEL=nomic-embed-text
LANCEDB_OPENCODE_PRO_OLLAMA_BASE_URL=http://ollama:11434

# === Ports ===
# Host port for OpenChamber Web UI
CHAMBER_PORT=8000
# Host port for Ollama API
OLLAMA_PORT=11434

# === Workspace ===
# Leave unset to use a Docker named volume (recommended for most users)
# Set to a host path for bind mount (e.g., ./workspace or /home/user/projects)
# WORKSPACE_PATH=./workspace
